/* pages/profile/profile.wxss - 个人中心样式 */

.user-card {
  padding: 40rpx 36rpx !important;
  border-radius: var(--radius-xl) !important;
  box-shadow: var(--shadow-md);
  background: linear-gradient(135deg, #FFFFFF 0%, #F9FAFF 100%);
}

.avatar {
  width: 104rpx; height: 104rpx; border-radius: 50%;
  background: var(--primary-gradient);
  display: flex; align-items: center; justify-content: center; font-size: 52rpx;
  box-shadow: var(--shadow-primary);
  flex-shrink: 0;
}

.user-name { font-size: 36rpx; font-weight: 800; letter-spacing: -0.5rpx; }
.user-slogan { font-size: 26rpx; color: var(--text-quaternary); margin-top: 4rpx; font-weight: 500; }

.user-stats { border-top: 1rpx solid var(--separator); padding-top: 24rpx; margin-top: 8rpx; }
.u-stat { text-align: center; flex: 1; }
.u-stat-num {
  font-size: 40rpx; font-weight: 800;
  background: var(--primary-gradient);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
}
.u-stat-label { font-size: 22rpx; color: var(--text-quaternary); margin-top: 2rpx; font-weight: 600; }

/* AI 配置卡片 */
.ai-config-card {
  padding: 32rpx !important;
  border-radius: var(--radius-xl) !important;
  box-shadow: var(--shadow-md);
}

.setting-item { padding: 12rpx 0; }
.setting-label {
  font-size: 30rpx; font-weight: 700;
  color: var(--text-primary);
  margin-bottom: 4rpx;
}
.setting-hint {
  font-size: 24rpx; color: var(--text-quaternary);
  line-height: 1.5;
  word-break: break-all;
}
.toggle-key {
  font-size: 26rpx; color: var(--primary); font-weight: 600;
  padding: 4rpx 8rpx;
}

/* 提供商选择器 */
.provider-selector {
  display: flex; gap: 16rpx; margin-top: 12rpx;
}
.provider-option {
  flex: 1;
  display: flex; flex-direction: column; align-items: center;
  padding: 24rpx 12rpx;
  border-radius: var(--radius-lg);
  background: var(--bg-input);
  border: 2rpx solid transparent;
  transition: all 0.2s ease;
}
.provider-option.active {
  background: var(--primary-light);
  border-color: var(--primary);
  box-shadow: 0 2rpx 16rpx rgba(79, 124, 255, 0.15);
}
.provider-icon { font-size: 40rpx; margin-bottom: 8rpx; }
.provider-name { font-size: 26rpx; font-weight: 600; color: var(--text-primary); }

/* API Key 输入 - 防溢出 */
.api-key-input-wrap {
  width: 100%;
  box-sizing: border-box;
  overflow: hidden;
}

.api-key-input {
  width: 100%;
  height: 88rpx;
  background: var(--bg-input);
  border-radius: var(--radius-md);
  padding: 0 28rpx;
  font-size: 28rpx;
  color: var(--text-primary);
  box-sizing: border-box;
  border: 2rpx solid transparent;
  transition: border-color 0.2s ease;
}

.api-key-input:focus {
  border-color: var(--primary);
  background: #fff;
}

/* 模型列表 */
.model-list {
  display: flex; flex-direction: column; gap: 8rpx;
}

.model-option {
  display: flex; align-items: center; justify-content: space-between;
  padding: 20rpx 24rpx;
  border-radius: var(--radius-md);
  background: var(--bg-input);
  transition: all 0.2s ease;
}

.model-option.active {
  background: var(--primary-light);
}

.model-option:active { transform: scale(0.98); }

.model-name {
  font-size: 28rpx; font-weight: 500; color: var(--text-primary);
}

.model-check {
  font-size: 28rpx; font-weight: 700; color: var(--primary);
}

/* 测试连接按钮 */
.test-btn {
  text-align: center;
  padding: 20rpx 0;
  border-radius: var(--radius-full);
  background: var(--bg-input);
  font-size: 28rpx;
  font-weight: 600;
  color: var(--primary);
  transition: all 0.2s ease;
}

.test-btn:active { transform: scale(0.97); background: var(--primary-light); }
.test-btn.loading { opacity: 0.6; pointer-events: none; }

.test-result {
  text-align: center;
  padding: 12rpx 0;
  font-size: 26rpx;
  font-weight: 500;
  margin-top: 12rpx;
}

.test-result.success { color: var(--success); }
.test-result.error { color: var(--danger); }

/* 菜单项 */
.menu-item {
  padding: 26rpx 0;
  transition: all 0.15s ease;
  font-weight: 500;
}
.menu-arrow { color: var(--text-quaternary); font-size: 28rpx; }

.footer-text {
  text-align: center; font-size: 22rpx;
  color: var(--text-quaternary); margin: 48rpx 0 24rpx;
  font-weight: 500; letter-spacing: 0.5rpx;
}
