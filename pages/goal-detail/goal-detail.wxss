/* pages/goal-detail/goal-detail.wxss - Apple 风格 */
.goal-info {
  padding: 36rpx 32rpx !important;
  border-radius: var(--radius-xl) !important;
  box-shadow: var(--shadow-md);
}
.goal-cat-badge {
  width: 60rpx; height: 60rpx; border-radius: 18rpx;
  display: flex; align-items: center; justify-content: center; font-size: 30rpx;
}
.goal-title-main { font-size: 36rpx; font-weight: 800; letter-spacing: -0.5rpx; }
.goal-desc { font-size: 28rpx; color: var(--text-secondary); margin-top: 16rpx; line-height: 1.6; }
.date-range { font-size: 24rpx; color: var(--text-quaternary); font-weight: 500; }
.more-btn { font-size: 40rpx; color: var(--text-quaternary); padding: 0 8rpx; }

.task-item {
  padding: 22rpx 24rpx !important; margin-bottom: 8rpx;
  border-radius: var(--radius-lg) !important;
  position: relative; overflow: hidden;
}
.task-item::before {
  content: ''; position: absolute; left: 0; top: 14rpx; bottom: 14rpx;
  width: 5rpx; border-radius: 3rpx; background: var(--primary); opacity: 0.4;
}
.task-t { font-size: 30rpx; font-weight: 600; letter-spacing: 0.3rpx; }
.task-t.line-through { text-decoration: line-through; color: var(--text-quaternary); }
.task-sub { font-size: 22rpx; color: var(--text-quaternary); margin-top: 4rpx; font-weight: 500; }
