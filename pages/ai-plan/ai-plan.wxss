/* pages/ai-plan/ai-plan.wxss - Apple 风格 AI 规划 */

.page-header {
  margin-bottom: 36rpx;
}

.page-title {
  font-size: 44rpx;
  font-weight: 800;
  margin-bottom: 12rpx;
  letter-spacing: -1rpx;
}

.page-desc {
  font-size: 28rpx;
  color: var(--text-tertiary);
  line-height: 1.6;
  font-weight: 400;
}

/* 输入区域 - 毛玻璃卡片 */
.input-section {
  padding: 36rpx !important;
  border-radius: var(--radius-xl) !important;
  box-shadow: var(--shadow-md);
}

.plan-input {
  width: 100%;
  min-height: 360rpx;
  font-size: 30rpx;
  color: var(--text-primary);
  line-height: 1.8;
  box-sizing: border-box;
  letter-spacing: 0.3rpx;
}

.input-footer {
  margin-top: 28rpx;
  padding-top: 24rpx;
  border-top: 1rpx solid var(--separator);
}

.char-count {
  font-size: 24rpx;
  color: var(--text-quaternary);
  font-weight: 500;
}

/* 加载动画 - Apple 风格脉冲 */
.loading-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 120rpx 0;
}

.loading-spinner {
  width: 80rpx;
  height: 80rpx;
  border: 5rpx solid var(--primary-light);
  border-top: 5rpx solid var(--primary);
  border-radius: 50%;
  animation: spin 0.8s cubic-bezier(0.5, 0, 0.5, 1) infinite;
  margin-bottom: 36rpx;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.loading-text {
  font-size: 32rpx;
  font-weight: 700;
  color: var(--text-primary);
  margin-bottom: 12rpx;
  letter-spacing: 0.5rpx;
}

.loading-hint {
  font-size: 26rpx;
  color: var(--text-quaternary);
}

.btn-primary.loading {
  opacity: 0.5;
  pointer-events: none;
}

/* 解析结果 */
.result-header {
  margin-bottom: 28rpx;
}

.parsed-item {
  padding: 28rpx 28rpx !important;
  margin-bottom: 12rpx;
  border-radius: var(--radius-lg) !important;
  position: relative;
  overflow: hidden;
}

.parsed-item::before {
  content: '';
  position: absolute;
  left: 0;
  top: 0;
  bottom: 0;
  width: 6rpx;
  background: var(--primary);
  border-radius: 0 3rpx 3rpx 0;
}

.parsed-item-header {
  align-items: center;
}

.category-badge {
  width: 52rpx;
  height: 52rpx;
  border-radius: 14rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 26rpx;
}

.parsed-title-input {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--text-primary);
  flex: 1;
  border-bottom: 2rpx dashed transparent;
  letter-spacing: 0.3rpx;
}

.parsed-title-input:focus {
  border-bottom-color: var(--primary);
}

.delete-btn {
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: var(--text-quaternary);
  font-size: 28rpx;
  border-radius: 50%;
  transition: all 0.2s ease;
}

.delete-btn:active {
  background: var(--danger-light);
  color: var(--danger);
  transform: scale(0.85);
}

.parsed-meta {
  flex-wrap: wrap;
  gap: 8rpx;
}

.parsed-date {
  font-size: 24rpx;
  color: var(--text-tertiary);
  font-weight: 500;
}

.parsed-desc {
  font-size: 26rpx;
  color: var(--text-secondary);
  margin-top: 12rpx;
  line-height: 1.5;
}

/* 确认按钮 */
.confirm-section {
  margin-top: 40rpx;
  padding-bottom: 60rpx;
}
