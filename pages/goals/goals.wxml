<!-- pages/goals/goals.wxml -->
<view class="container fade-in">
  <view class="page-header flex-between">
    <view class="page-title">🎯 我的目标</view>
    <view class="btn-secondary" bindtap="showAddGoal">+ 新目标</view>
  </view>

  <!-- 筛选 -->
  <view class="filter-bar flex-row" style="gap:12rpx;margin-bottom:24rpx;">
    <view class="filter-tag {{filter==='all'?'active':''}}" bindtap="setFilter" data-f="all">全部</view>
    <view class="filter-tag {{filter==='active'?'active':''}}" bindtap="setFilter" data-f="active">进行中</view>
    <view class="filter-tag {{filter==='completed'?'active':''}}" bindtap="setFilter" data-f="completed">已完成</view>
  </view>

  <block wx:if="{{goals.length > 0}}">
    <view class="goal-item card" wx:for="{{goals}}" wx:key="_id"
          bindtap="goDetail" data-id="{{item._id}}">
      <view class="flex-between">
        <view class="flex-row" style="gap:12rpx;">
          <view class="goal-cat-icon" style="background:{{item.catColor}}20;">{{item.catIcon}}</view>
          <view>
            <view class="goal-name">{{item.title}}</view>
            <view class="goal-date">{{item.startDate}} ~ {{item.endDate}}</view>
          </view>
        </view>
        <view class="goal-progress-ring">
          <view class="ring-text">{{item.progress}}%</view>
        </view>
      </view>
      <view class="progress-bar" style="margin-top:16rpx;">
        <view class="progress-bar-fill" style="width:{{item.progress}}%;background:{{item.catColor}};"></view>
      </view>
    </view>
  </block>

  <view wx:else class="empty-state">
    <view class="empty-state-icon">🎯</view>
    <view class="empty-state-text">还没有目标\n试试「AI 规划」自动创建</view>
  </view>
</view>

<!-- 新建目标弹窗 -->
<view class="overlay" wx:if="{{showModal}}" bindtap="hideModal"></view>
<view class="modal slide-up" wx:if="{{showModal}}">
  <view class="modal-title">新建目标</view>
  <view class="form-group">
    <input class="input-field" placeholder="目标名称" value="{{form.title}}" bindinput="onInput" data-f="title" />
  </view>
  <view class="form-group">
    <textarea class="textarea-field" placeholder="目标描述（可选）" value="{{form.description}}"
              bindinput="onInput" data-f="description" style="min-height:120rpx;" />
  </view>
  <view class="form-group">
    <view class="label">分类</view>
    <view class="cat-selector flex-row" style="flex-wrap:wrap;gap:12rpx;">
      <view class="cat-option {{form.category===item.id?'active':''}}" wx:for="{{categories}}" wx:key="id"
            bindtap="setCat" data-id="{{item.id}}" style="border-color:{{form.category===item.id?item.color:'transparent'}}">
        {{item.icon}} {{item.name}}
      </view>
    </view>
  </view>
  <view class="form-group flex-row" style="gap:16rpx;">
    <picker mode="date" value="{{form.startDate}}" bindchange="onDateChange" data-f="startDate" style="flex:1;">
      <view class="input-field">开始: {{form.startDate}}</view>
    </picker>
    <picker mode="date" value="{{form.endDate}}" bindchange="onDateChange" data-f="endDate" style="flex:1;">
      <view class="input-field">截止: {{form.endDate}}</view>
    </picker>
  </view>
  <view class="modal-actions flex-between">
    <view class="btn-ghost" bindtap="hideModal" style="flex:1;text-align:center;margin-right:16rpx;">取消</view>
    <view class="btn-primary" bindtap="saveGoal" style="flex:1;text-align:center;">创建</view>
  </view>
</view>
