/* pages/feedback/feedback.wxss - Apple 风格 */
.page-title { font-size: 44rpx; font-weight: 800; letter-spacing: -1rpx; }
.page-desc { font-size: 28rpx; color: var(--text-tertiary); margin-top: 8rpx; font-weight: 400; }

.type-selector { flex-wrap: wrap; }
.type-option {
  padding: 14rpx 28rpx; border-radius: var(--radius-full);
  background: var(--bg-input); font-size: 26rpx;
  border: 2rpx solid transparent; font-weight: 600;
  transition: all 0.2s ease;
}
.type-option.active {
  background: var(--primary-light); border-color: var(--primary); color: var(--primary);
  box-shadow: 0 2rpx 12rpx rgba(79, 124, 255, 0.15);
}

.char-count { font-size: 22rpx; color: var(--text-quaternary); text-align: right; margin-top: 8rpx; font-weight: 500; }
