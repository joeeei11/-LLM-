/* pages/stats/stats.wxss - Apple 风格数据统计 */
.page-title { font-size: 44rpx; font-weight: 800; margin-bottom: 28rpx; letter-spacing: -1rpx; }

.metrics-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 12rpx; margin-bottom: 20rpx; }
.metric-card {
  text-align: center; padding: 28rpx 16rpx !important;
  border-radius: var(--radius-xl) !important;
  box-shadow: var(--shadow-md);
}
.metric-value {
  font-size: 48rpx; font-weight: 800; letter-spacing: -1rpx;
}
.metric-label { font-size: 22rpx; color: var(--text-quaternary); margin-top: 4rpx; font-weight: 600; letter-spacing: 0.5rpx; }

.chart-section {
  margin-bottom: 20rpx; padding: 32rpx !important;
  border-radius: var(--radius-xl) !important;
  box-shadow: var(--shadow-md);
}
.trend-chart { margin-top: 20rpx; max-height: 600rpx; overflow-y: auto; }
.trend-bar-row { display: flex; align-items: center; gap: 12rpx; margin-bottom: 14rpx; }
.trend-date { font-size: 24rpx; color: var(--text-quaternary); width: 88rpx; flex-shrink: 0; font-weight: 600; }
.trend-bar-bg { flex: 1; height: 20rpx; background: var(--bg-input); border-radius: 10rpx; overflow: hidden; }
.trend-bar-fill {
  height: 100%; border-radius: 10rpx;
  background: var(--primary-gradient);
  transition: width 0.6s cubic-bezier(0.25, 0.46, 0.45, 0.94);
}
.trend-rate { font-size: 24rpx; color: var(--text-secondary); width: 64rpx; text-align: right; flex-shrink: 0; font-weight: 600; }

.cat-stat-item { padding: 18rpx 0; border-bottom: 1rpx solid var(--separator); }
.cat-stat-item:last-child { border-bottom: none; }
.cat-bar-bg { width: 200rpx; height: 16rpx; background: var(--bg-input); border-radius: 8rpx; overflow: hidden; }
.cat-bar-fill { height: 100%; border-radius: 8rpx; transition: width 0.6s cubic-bezier(0.25, 0.46, 0.45, 0.94); }

.list-item {
  display: flex; justify-content: space-between; align-items: center;
  padding: 28rpx 32rpx !important; margin-bottom: 8rpx;
  border-radius: var(--radius-lg) !important;
  transition: all 0.15s ease;
}
.list-item:active { background: var(--bg-input); }
